<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.comment.mapper.CommentMapper">
    <update id="updateComment">
        UPDATE comment_tbl
        SET content = #{content}
        WHERE id = #{id}
    </update>
</mapper>