<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.thinking.mapper.ThinkingMapper">
    <insert id="create">
        INSERT INTO thinking_tbl (category, title, content, password)
        VALUES (#{category}, #{title}, #{content}, #{password})

        <selectKey resultType="Long" keyProperty="id" keyColumn="id" order="AFTER">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <select id="getList" resultType="org.scoula.thinking.domain.ThinkingVO">
        SELECT * FROM thinking_tbl
    </select>
</mapper>