<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.thinking.mapper.ThinkingMapper">
    <select id="getList" resultType="org.scoula.thinking.domain.ThinkingVO">
        SELECT * FROM thinking_tbl
    </select>
    <select id="getListOne" resultType="org.scoula.thinking.domain.ThinkingVO">
        SELECT
            id,category, title, content, password, like_count, created_at, updated_at
        FROM thinking_tbl
        WHERE id = #{id}
    </select>
</mapper>