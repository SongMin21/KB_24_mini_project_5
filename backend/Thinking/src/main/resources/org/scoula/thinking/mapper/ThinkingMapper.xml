<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.thinking.mapper.ThinkingMapper">
    <update id="update">
        update thinking_tbl set
        category = #{category},
        title = #{title},
        content = #{content},
        updated_at = now()
        where id = #{id}
    </update>

<!--    <delete id="delete">-->
<!--        delete from thinking_tbl where no = #{no}-->
<!--    </delete>-->

    <select id="getList" resultType="org.scoula.thinking.domain.ThinkingVO">
        SELECT * FROM thinking_tbl
    </select>
</mapper>